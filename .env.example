# FarmERP Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Prisma - Database connection
# Use pooled connection for runtime (port 6543)
DATABASE_URL="postgresql://postgres:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use direct connection for migrations (port 5432)
DIRECT_URL="postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres"

# App
NEXT_PUBLIC_APP_NAME=FarmERP
NEXT_PUBLIC_APP_URL=http://localhost:3000
